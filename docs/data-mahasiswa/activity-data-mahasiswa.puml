@startuml
title Activity Diagram - Data Mahasiswa (Mentor Only)

skinparam ActivityBackgroundColor #E8F5E9
skinparam ActivityBorderColor #2E7D32
skinparam ActivityDiamondBackgroundColor #FFF9C4
skinparam ActivityDiamondBorderColor #F57F17
skinparam SwimlaneBorderColor #1565C0
skinparam TitleFontSize 18
skinparam ActivityFontSize 13

|Mentor|
start
:Membuka halaman Data Mahasiswa;

|Sistem|
:Mengambil data mahasiswa bimbingan\ndan statistik (aktif, selesai) dari server;
:Menampilkan daftar mahasiswa;

|Mentor|
if (Aksi yang dipilih?) then (filter/cari)
  :Memasukkan kata kunci pencarian\natau memilih filter (Gender/Univ/Status);
  |Sistem|
  :Menyaring dan menampilkan\nhasil yang relevan;
  |Mentor|
  :Melihat hasil pencarian;
  stop

elseif (tambah) then
  :Mengarahkan ke halaman "Tambah Mahasiswa";
  |Sistem|
  :Menampilkan form registrasi;
  |Mentor|
  :Mengisi data diri mahasiswa\ndan periode magang;
  :Klik "Simpan";
  |Sistem|
  :Menyimpan data mahasiswa baru;
  :Mengarahkan kembali ke halaman utama;
  |Mentor|
  stop

elseif (edit / hapus) then
  :Klik ikon Edit atau Hapus\npada baris tabel;
  |Sistem|
  :Mengarahkan ke halaman form Edit\natau Hapus Mahasiswa;
  |Mentor|
  if (Pilihan aksi lanjutan?) then (edit)
    :Mengubah data mahasiswa;
    :Menyimpan perubahan;
    |Sistem|
    :Memperbarui data di server;
  else (hapus)
    :Mengonfirmasi penghapusan data;
    |Sistem|
    :Menghapus data mahasiswa dari server;
  endif
  :Mengarahkan kembali ke tabel utama;
  |Mentor|
  stop

else (ubah status periode)
  :Mengubah dropdown Status Periode\n(Aktif / Selesai / Batal) pada tabel;
  |Sistem|
  :Mengirim pembaruan status ke server;
  :Memperbarui tampilan;
  |Mentor|
  stop
endif

@enduml
