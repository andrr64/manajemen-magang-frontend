@startuml
title Activity Diagram - Login

skinparam ActivityBackgroundColor #E8F5E9
skinparam ActivityBorderColor #2E7D32
skinparam ActivityDiamondBackgroundColor #FFF9C4
skinparam ActivityDiamondBorderColor #F57F17
skinparam SwimlaneBorderColor #1565C0
skinparam TitleFontSize 18
skinparam ActivityFontSize 13

|Pengguna (Mahasiswa / Mentor)|
start
:Membuka halaman login;
:Mengisi email dan password;
:Klik tombol "Masuk Ke Sistem";

|Sistem|
:Validasi input form;
if (Apakah input sudah terisi?) then (ya)
  :Mengirim kredensial ke server;
  :Verifikasi email dan password;
  if (Apakah kredensial valid?) then (ya)
    :Menyimpan data otentikasi (user, token)\ndi IAM Store;
    if (Role pengguna?) then (mahasiswa)
      :Redirect ke halaman\n/dashboard/mahasiswa;
    else (mentor)
      :Redirect ke halaman\n/dashboard/mentor;
    endif
    |Pengguna (Mahasiswa / Mentor)|
    :Melihat tampilan Dashboard\nsesuai dengan role masing-masing;
    stop
  else (tidak)
    |Sistem|
    :Menampilkan pesan error\n"Akses ditolak. Kredensial tidak valid.";
    |Pengguna (Mahasiswa / Mentor)|
    :Mengisi ulang email dan password;
    stop
  endif
else (tidak)
  |Sistem|
  :Menampilkan pesan error\n"Email dan Sandi wajib diisi";
  |Pengguna (Mahasiswa / Mentor)|
  :Melengkapi input;
  stop
endif

@enduml
