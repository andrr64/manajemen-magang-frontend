@startuml
title Activity Diagram - Kelola Profil (Mahasiswa & Mentor)

skinparam ActivityBackgroundColor #E8F5E9
skinparam ActivityBorderColor #2E7D32
skinparam ActivityDiamondBackgroundColor #FFF9C4
skinparam ActivityDiamondBorderColor #F57F17
skinparam SwimlaneBorderColor #1565C0
skinparam TitleFontSize 18
skinparam ActivityFontSize 13

|Pengguna (Mahasiswa / Mentor)|
start
:Membuka halaman Profil;

|Sistem|
:Mengambil data sesi pengguna\ndari server (Store IAM);
:Menampilkan Kartu Identitas\ndan form Ubah Profil;

|Pengguna (Mahasiswa / Mentor)|
:Mengubah data diri (Nama, Email, No. HP)\natau mengganti Kata Sandi;
:Klik "Simpan Perubahan Profil";

|Sistem|
:Memvalidasi input;
if (Apakah input terisi dengan benar?) then (ya)
  :Mengirim pembaruan data\nprofil ke server;
  if (Apakah pembaruan berhasil?) then (ya)
    :Memperbarui state pengguna\ndi aplikasi;
    :Menampilkan notifikasi (Toast)\n"Profil berhasil diperbarui";
    |Pengguna (Mahasiswa / Mentor)|
    :Melihat data profil terbaru;
    stop
  else (tidak)
    |Sistem|
    :Menampilkan pesan error\n(Misal: Password lama salah);
    |Pengguna (Mahasiswa / Mentor)|
    :Memperbaiki data form;
    stop
  endif
else (tidak)
  |Sistem|
  :Mencegah penyimpanan dan\nmenampilkan peringatan kolom;
  |Pengguna (Mahasiswa / Mentor)|
  :Melengkapi data form;
  stop
endif

@enduml
