@startuml
title Activity Diagram - Penilaian (Mentor & Mahasiswa)

skinparam ActivityBackgroundColor #E8F5E9
skinparam ActivityBorderColor #2E7D32
skinparam ActivityDiamondBackgroundColor #FFF9C4
skinparam ActivityDiamondBorderColor #F57F17
skinparam SwimlaneBorderColor #1565C0
skinparam TitleFontSize 18
skinparam ActivityFontSize 13

|Mentor|
start
:Membuka halaman Penilaian;

|Sistem|
:Mengambil daftar mahasiswa\nbimbingan dari server;
:Menampilkan statistik dan\ndaftar mahasiswa;

|Mentor|
if (Aksi yang dilakukan?) then (Cari/Filter)
  :Memasukkan kata kunci pencarian\natau mengubah filter status;
  |Sistem|
  :Menyaring dan menampilkan\nhasil pencarian;
  |Mentor|
  :Melihat hasil pencarian;
  stop
else (Beri / Edit Nilai)
  :Klik aksi "Beri Nilai" atau\n"Edit Nilai" pada baris tabel;
  |Sistem|
  :Mengarahkan ke halaman form\npenilaian mahasiswa terkait;
  |Mentor|
  :Mengisi skor per kriteria\ndan catatan tambahan (opsional);
  :Klik "Simpan Penilaian";
  |Sistem|
  :Memvalidasi dan menyimpan\ndata penilaian;
  :Memperbarui status mahasiswa\nmenjadi "Sudah Dinilai";
  :Mengarahkan kembali ke\nhalaman tabel utama;
  |Mentor|
  :Melihat status penilaian\nterbaru;
  stop
endif

== Mahasiswa Melihat Penilaian ==

|Mahasiswa|
start
:Membuka halaman Penilaian;

|Sistem|
:Mengambil data penilaian\nmahasiswa terkait dari server;
if (Status penilaian?) then (Sudah Dinilai)
  :Menampilkan nilai akhir, Grade,\nrincian skor kriteria,\ndan catatan Mentor;
  |Mahasiswa|
  if (Aksi lanjutan?) then (Preview Rekap)
    :Klik tab "Preview Rekap";
    |Sistem|
    :Menampilkan preview dokumen\npenilaian magang;
    |Mahasiswa|
    stop
  else (Download PDF)
    :Klik tombol "Download Rekap";
    |Sistem|
    :Meng-generate dokumen PDF\nbeserta Tanda Tangan (TTD);
    :Mengirimkan file PDF untuk\ndiunduh ke perangkat;
    |Mahasiswa|
    stop
  endif
else (Belum Dinilai)
  |Sistem|
  :Menampilkan status peringatan\n"Menunggu Penilaian";
  |Mahasiswa|
  stop
endif

@enduml
