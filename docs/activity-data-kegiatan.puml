@startuml
title Activity Diagram - Data Kegiatan (Mahasiswa & Mentor)

skinparam ActivityBackgroundColor #E8F5E9
skinparam ActivityBorderColor #2E7D32
skinparam ActivityDiamondBackgroundColor #FFF9C4
skinparam ActivityDiamondBorderColor #F57F17
skinparam SwimlaneBorderColor #1565C0
skinparam TitleFontSize 18
skinparam ActivityFontSize 13

|Mahasiswa|
start
:Membuka halaman kegiatan;

|Sistem|
:Mengambil data kegiatan\ndari server;
:Menampilkan daftar kegiatan;

|Mahasiswa|
if (Aksi yang dipilih?) then (tambah)
  :Klik "Tambah Kegiatan";
  |Sistem|
  :Menampilkan modal/form tambah;
  |Mahasiswa|
  :Mengisi tanggal, deskripsi, dan\nmengunggah dokumen lampiran;
  :Klik "Simpan";
  |Sistem|
  :Menyimpan kegiatan dengan\nstatus awal "Dalam Review";
  :Memperbarui daftar kegiatan;
  |Mahasiswa|
  :Melihat kegiatan terbaru;
  stop
elseif (edit) then
  :Klik kegiatan / ikon edit;
  |Sistem|
  :Menampilkan form edit\ndengan data terisi;
  |Mahasiswa|
  :Mengubah data atau lampiran;
  :Klik "Simpan";
  |Sistem|
  :Menyimpan perubahan ke server;
  :Memperbarui daftar kegiatan;
  |Mahasiswa|
  :Melihat kegiatan terbaru;
  stop
else (hapus)
  :Klik ikon hapus\npada kegiatan;
  |Sistem|
  :Menampilkan dialog konfirmasi;
  |Mahasiswa|
  if (Konfirmasi hapus?) then (ya)
    |Sistem|
    :Menghapus data kegiatan\ndan lampirannya;
    :Memperbarui daftar kegiatan;
    |Mahasiswa|
    :Melihat daftar terbaru;
    stop
  else (tidak)
    |Sistem|
    :Menutup dialog;
    |Mahasiswa|
    stop
  endif
endif

|Mentor|
start
:Membuka halaman Data Kegiatan;
|Sistem|
:Menampilkan daftar kegiatan\nseluruh mahasiswa bimbingan;
|Mentor|
if (Aksi verifikasi?) then (setujui)
  :Klik ikon "Ceklis" (Setujui);
  |Sistem|
  :Mengubah status kegiatan\nmenjadi "Disetujui";
  :Memperbarui daftar dan statistik;
  |Mentor|
  stop
elseif (cabut persetujuan) then
  :Klik ikon "Revoke" (Cabut);
  |Sistem|
  :Mengembalikan status kegiatan\nmenjadi "Dalam Review";
  :Memperbarui daftar dan statistik;
  |Mentor|
  stop
else (hapus)
  :Klik ikon "Trash" (Hapus);
  |Sistem|
  :Menampilkan dialog konfirmasi;
  |Mentor|
  if (Konfirmasi hapus?) then (ya)
    |Sistem|
    :Menghapus log kegiatan mahasiswa\nsecara permanen;
    :Memperbarui daftar;
    |Mentor|
    stop
  else (tidak)
    stop
  endif
endif

@enduml
