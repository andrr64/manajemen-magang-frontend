@startuml
title Activity Diagram - Surat Keterangan Selesai Magang (SKSM)

skinparam ActivityBackgroundColor #E8F5E9
skinparam ActivityBorderColor #2E7D32
skinparam ActivityDiamondBackgroundColor #FFF9C4
skinparam ActivityDiamondBorderColor #F57F17
skinparam SwimlaneBorderColor #1565C0
skinparam TitleFontSize 18
skinparam ActivityFontSize 13

|Mentor|
start
:Membuka halaman Surat Keterangan;

|Sistem|
:Mengambil data SKSM mahasiswa\nbimbingan beserta statistik;
:Menampilkan daftar berkas SKSM\ndan status unggahan;

|Mentor|
if (Aksi yang dilakukan?) then (Cari/Filter)
  :Mencari nama/NIM atau memfilter\nberdasarkan status berkas;
  |Sistem|
  :Menyaring dan menampilkan hasil;
  |Mentor|
  :Melihat hasil pencarian;
  stop
else (Kelola/Unggah SKSM)
  :Klik aksi "Unggah Surat" atau\n"Kelola Surat" pada baris tabel;
  |Sistem|
  :Mengarahkan ke halaman\nform unggah dokumen;
  |Mentor|
  :Mengunggah file PDF SKSM;
  |Sistem|
  :Memproses pengunggahan file\ndan menyimpan tautan;
  if (Apakah unggahan berhasil?) then (ya)
    :Memperbarui status menjadi\n"Sudah Diunggah";
    |Mentor|
    :Melihat status berkas terbaru;
    stop
  else (tidak)
    |Sistem|
    :Menampilkan pesan error;
    |Mentor|
    stop
  endif
endif

|Mahasiswa|
start
:Membuka halaman Surat Keterangan;

|Sistem|
:Mengambil data SKSM\nberdasarkan pengguna yang login;

if (Apakah ada periode magang?) then (tidak)
  :Menampilkan pesan\n"Tidak ada periode magang aktif";
  |Mahasiswa|
  stop
else (ya)
  if (Status SKSM?) then (Sudah Diunggah)
    :Menampilkan detail metadata SKSM\ndan tombol unduhan;
    |Mahasiswa|
    :Klik tombol "Unduh / Buka Surat Keterangan";
    |Sistem|
    :Membuka/mengunduh file dokumen\nSKSM dari tautan server;
    |Mahasiswa|
    :Menerima file SKSM;
    stop
  else (Belum Diunggah)
    |Sistem|
    :Menampilkan status peringatan\n"Menunggu Surat Keterangan dari Mentor";
    |Mahasiswa|
    stop
  endif
endif

@enduml
